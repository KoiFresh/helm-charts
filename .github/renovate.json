{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "platform": "github",
  "requireConfig": "ignored",
  "onboarding": false,
  "labels": [
    "renovatebot"
  ],
  "extends": [
    "config:recommended"
  ],
  "repositories": [
    "koifresh/helm-charts"
  ],
  "gitAuthor": "Renovate Bot <homelab@mayer.sh>",
  "assignees": [
    "koifresh"
  ],
  "helmv3": {
    "managerFilePatterns": [
      "/(^|/)Chart\\.ya?ml$/"
    ]
  },
  "bumpVersions": [
    {
      "filePatterns": [
        "{{packageFileDir}}/Chart.{yaml,yml}"
      ],
      "matchStrings": [
        "version:\\s(?<version>[^\\s]+)"
      ],
      "bumpType": "{{#if isPatch}}patch{{else}}minor{{/if}}"
    }
  ]
}